@inject IJSRuntime JSRuntime
@using JobTracker.Data
@using JobTracker.Models

@if (IsModalVisible){
    <div class="modal-container">
        <div class="modal-content-container">
            <div class="modal-header">
                <div class="modal-header-left">
                    <h1 class="modal-header-title">
                        @(string.IsNullOrEmpty(jobTitleInput) ? "Job Title" : jobTitleInput)
                    </h1>

                    <small>
                        @(string.IsNullOrEmpty(companyNameInput) ? "Company Name" : companyNameInput)
                    </small>
                    <small>
                        <b>•</b> @statusInput
                    </small>
                </div>

                <div class="modal-header-right">
                    <button class="cancel" @onclick="CloseJobModal">
                        Cancel
                    </button>
                    <button class="save" @onclick="SaveJobApp">
                        Save
                    </button>
                </div>
            </div>

            <div class="modal-body">

                <div class="hw-row">
                    <div>
                        <p>Company Name</p>
                        <input type="text" class="input" @bind="companyNameInput" placeholder="Company Name" />
                    </div>
                    <div>
                        <p>Job Title</p>
                        <input type="text" @bind="jobTitleInput" class="input" placeholder="Job Title" />
                    </div>
                </div>

                <div class="hw-row">
                    <div>
                        <p>Location</p>
                        <input type="text" class="input" @bind="locationInput" placeholder="Location" />
                    </div>
                    <div>
                        <p>Date Applied</p>
                        <input type="date" @bind="dateAppliedInput" class="input" />
                    </div>
                </div>

                <div class="hw-row">
                    <div>
                        <p>Status</p>
                        <select class="input" @bind="statusInput" required>
                            <option value="" disabled hidden selected>Status</option>
                            <option>Interested</option>
                            <option>Applied</option>
                            <option>Interview</option>
                            <option>Offer</option>
                            <option>Rejected</option>
                        </select>
                    </div>
                    <div>
                        <p>Closing Date</p>
                        <input type="date" @bind="dateCloseInput" class="input" />
                    </div>
                </div>

                <div class="row">
                    <div>
                        <p>Link</p>
                        <input type="url" class="input" @bind="linkInput" placeholder="Link" />
                    </div>
                </div>

                <div class="row">
                    <div>
                        <p>Description</p>
                        <textarea class="input description" @bind="descriptionInput" placeholder="Job Description"></textarea>
                    </div>
                </div>

                <div class="hw-row">
                    <div>
                        <p>CV</p>
                        <input type="file" id="fileInput" class="input" onchange="HandleCvUpload" />
                    </div>
                    <div>
                        <p>Cover Letter</p>
                        <input type="file" id="fileInput" class="input" onchange="HandleCoverLetterUpload" />
                    </div>
                </div>


            </div>
        </div>
    </div>

}


@code {
    [Parameter] public bool IsModalVisible { get; set; } // Controls modal visibility
    [Parameter] public EventCallback CloseModal { get; set; } // Event to close the modal
    [Inject] private JobApplicationDatabase JobDb { get; set; }

    private string companyNameInput = "";
    private string jobTitleInput = "";
    private string statusInput = "Status";
    private string locationInput = "";
    private DateTime? dateAppliedInput { get; set; } = null;
    private DateTime? dateCloseInput { get; set; } = null;
    private string linkInput = "";
    private string descriptionInput = "";
    private IBrowserFile? cvFile;
    private IBrowserFile? coverLetterFile;

    private async Task SaveJobApp()
    {
        // if (string.IsNullOrWhiteSpace(companyNameInput) ||
        //     string.IsNullOrWhiteSpace(jobTitleInput) ||
        //     string.IsNullOrWhiteSpace(statusInput) || statusInput == "Status" ||
        //     string.IsNullOrWhiteSpace(locationInput) ||
        //     string.IsNullOrWhiteSpace(descriptionInput) ||
        //     string.IsNullOrWhiteSpace(linkInput) ||
        //     dateAppliedInput is null ||
        //     dateCloseInput is null ||
        //     cvFile is null ||
        //     coverLetterFile is null)
        // {
        //     await JSRuntime.InvokeVoidAsync("alert", "Please fill in all fields and upload both files.");
        //     return;
        // }

        //Needa fix this issue

        // var cvPath = await SaveUploadedFileAsync(cvFile);
        // var coverLetterPath = await SaveUploadedFileAsync(coverLetterFile);

        var jobApp = new JobApplication
            {
                CompanyName = companyNameInput,
                JobTitle = jobTitleInput,
                Status = statusInput,
                Location = locationInput,
                DateApplied = dateAppliedInput!.Value,
                DateClosing = dateCloseInput!.Value,
                Link = linkInput,
                Description = descriptionInput,
                // CvFilePath = cvPath,
                // CoverLetterFilePath = coverLetterPath
                CvFilePath = "test",
                CoverLetterFilePath = "test"
            };

        // await JobDb.SaveJobApplicationAsync(jobApp);
        // await CloseJobModal();

        // Call SaveJobApplicationAsync and store the result
        var result = await JobDb.SaveJobApplicationAsync(jobApp);

        // Alert the integer value returned by SaveJobApplicationAsync
        await JSRuntime.InvokeVoidAsync("alert", $"Rows affected: {result}");

        // Optionally check the result for success
        if (result > 0)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Job Application Saved Successfully!");
            await CloseJobModal();
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("alert", "Failed to Save Job Application!");
        }

    }

    private async Task CloseJobModal()
    {
        await CloseModal.InvokeAsync(); // Trigger the close modal action from the parent

        cvFile = null;
        coverLetterFile = null;
        companyNameInput = string.Empty;
        jobTitleInput = string.Empty;
        statusInput = "Status";
        locationInput = string.Empty;
        descriptionInput = string.Empty;
        linkInput = string.Empty;
        dateAppliedInput = null;
        dateCloseInput = null;


    }

    private void HandleCvUpload(InputFileChangeEventArgs e)
    {
        cvFile = e.File;
    }

    private void HandleCoverLetterUpload(InputFileChangeEventArgs e)
    {
        coverLetterFile = e.File;
    }

    private async Task<string> SaveUploadedFileAsync(IBrowserFile file)
    {
        var fileName = $"{Guid.NewGuid()}_{file.Name}";
        var path = Path.Combine(FileSystem.AppDataDirectory, fileName);

        using var stream = file.OpenReadStream();
        using var fileStream = File.Create(path);
        await stream.CopyToAsync(fileStream);

        return path;
    }

}
